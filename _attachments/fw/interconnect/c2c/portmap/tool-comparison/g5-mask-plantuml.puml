@startuml
title PlantUML source: G5 first hop -> 8bit mask
skinparam backgroundColor #F8FAFC
skinparam rectangle {
  RoundCorner 12
  BorderColor #CBD5E1
}

rectangle "G5\nsource GPU" as G5 #1D4ED8
rectangle "UP\n11000000\nupper serdes group" as UP #DBEAFE
rectangle "RIGHT\n00110000\nright serdes group" as RIGHT #FEF3C7
rectangle "DOWN\n00001100\nlower serdes group" as DOWN #FCE7F3
rectangle "LEFT\n00000011\nleft serdes group" as LEFT #DCFCE7

G5 --> UP : target above
G5 --> RIGHT : G5 -> G10
G5 --> DOWN : G5 -> G13
G5 --> LEFT : G5 -> G0

note right of RIGHT
  portmap entry only encodes first-hop C2C exit.
  It does not encode the destination GPU or full path.
end note
@enduml
