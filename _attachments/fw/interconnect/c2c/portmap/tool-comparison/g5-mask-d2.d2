direction: right

title: "D2: G5 first hop -> 8bit mask"

g5: "G5\nsource GPU" {
  shape: circle
  style.fill: "#1D4ED8"
  style.stroke: "#1E3A8A"
  style.font-color: "#FFFFFF"
}

mask_up: "UP\n11000000\nupper serdes group" {
  style.fill: "#DBEAFE"
  style.stroke: "#60A5FA"
}
mask_right: "RIGHT\n00110000\nright serdes group" {
  style.fill: "#FEF3C7"
  style.stroke: "#F59E0B"
}
mask_down: "DOWN\n00001100\nlower serdes group" {
  style.fill: "#FCE7F3"
  style.stroke: "#F472B6"
}
mask_left: "LEFT\n00000011\nleft serdes group" {
  style.fill: "#DCFCE7"
  style.stroke: "#22C55E"
}

examples: {
  label: "examples"
  g10: "G5 -> G10\nfirst hop right"
  g0: "G5 -> G0\nfirst hop left"
  g13: "G5 -> G13\nfirst hop down"
}

g5 -> mask_up: "target above"
g5 -> mask_right: "G5 -> G10"
g5 -> mask_down: "G5 -> G13"
g5 -> mask_left: "G5 -> G0"
mask_right -> examples.g10
mask_left -> examples.g0
mask_down -> examples.g13
