digraph G {
  graph [rankdir=LR, bgcolor="#F8FAFC", pad="0.35", nodesep="0.75", ranksep="1.0", fontname="Microsoft YaHei"];
  node [shape=rect, style="rounded,filled", fontname="Microsoft YaHei", fontsize=13, color="#CBD5E1", fillcolor="#FFFFFF"];
  edge [fontname="Microsoft YaHei", fontsize=11, color="#64748B", arrowsize=0.8];

  topology [shape=plain, label=<
    <TABLE BORDER="1" CELLBORDER="1" CELLSPACING="6" CELLPADDING="12" COLOR="#CBD5E1">
      <TR><TD BGCOLOR="#FFFFFF" COLSPAN="4"><B>Graphviz DOT: 4x4 topology, source G5</B></TD></TR>
      <TR>
        <TD BGCOLOR="#EFF6FF">G0</TD>
        <TD BGCOLOR="#DBEAFE"><B>G1</B><BR/>UP</TD>
        <TD BGCOLOR="#EFF6FF">G2</TD>
        <TD BGCOLOR="#EFF6FF">G3</TD>
      </TR>
      <TR>
        <TD BGCOLOR="#DCFCE7"><B>G4</B><BR/>LEFT</TD>
        <TD BGCOLOR="#1D4ED8"><FONT COLOR="white"><B>G5</B><BR/>source</FONT></TD>
        <TD BGCOLOR="#FEF3C7"><B>G6</B><BR/>RIGHT</TD>
        <TD BGCOLOR="#FEF3C7"><B>G7</B><BR/>RIGHT</TD>
      </TR>
      <TR>
        <TD BGCOLOR="#EFF6FF">G8</TD>
        <TD BGCOLOR="#FCE7F3"><B>G9</B><BR/>DOWN</TD>
        <TD BGCOLOR="#FEF3C7"><B>G10</B><BR/>RIGHT/DOWN</TD>
        <TD BGCOLOR="#FEF3C7"><B>G11</B><BR/>RIGHT/DOWN</TD>
      </TR>
      <TR>
        <TD BGCOLOR="#EFF6FF">G12</TD>
        <TD BGCOLOR="#FCE7F3"><B>G13</B><BR/>DOWN</TD>
        <TD BGCOLOR="#EFF6FF">G14</TD>
        <TD BGCOLOR="#EFF6FF">G15</TD>
      </TR>
    </TABLE>
  >];

  up [label="UP\n11000000", fillcolor="#DBEAFE", color="#60A5FA"];
  right_mask [label="RIGHT\n00110000", fillcolor="#FEF3C7", color="#F59E0B"];
  down [label="DOWN\n00001100", fillcolor="#FCE7F3", color="#F472B6"];
  left_mask [label="LEFT\n00000011", fillcolor="#DCFCE7", color="#22C55E"];
  note [label="portmap entry only encodes\nfirst-hop C2C exit", shape=note, fillcolor="#FFFFFF", color="#94A3B8"];

  topology -> up [label="target above"];
  topology -> right_mask [label="G5 -> G10"];
  topology -> down [label="G5 -> G13"];
  topology -> left_mask [label="G5 -> G0"];
  up -> note;
  right_mask -> note;
  down -> note;
  left_mask -> note;
}