flowchart TD
  A["UART RX data arrives"] --> B["drv_usart_irq_handler"]
  B --> C["dev.rx_indicate(dev, 1)"]
  C --> D["agc_shell_rx_ind"]
  D --> E["rt_device_read: read 1 byte"]
  E --> F["rt_ringbuffer_put(input_buff)"]
  F --> G["rt_sem_release(rx_sem)"]
  G --> H["rt_schedule"]
  H --> I["agc_shell_thread_entry"]
  I --> J["agc_shell_parse"]
  J --> K["agc_shell_getchar"]
  K --> L["switch one char"]
  L --> M["agc_shell_ctrl_default / enter / arrow / backspace"]
  M --> N["rt_kprintf echo or command output"]
  N --> O["drv_usart_write byte-by-byte"]
