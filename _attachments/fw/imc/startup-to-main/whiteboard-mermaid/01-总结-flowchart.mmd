flowchart TD
  Reset["IMC reset / image entry"] --> Linker["link.lds: ENTRY(_start)"]
  Linker --> Start["start.S: _start"]
  Start --> CpuEnv["关中断，设置 gp/tp/sp，配置 ECLIC/mtvec"]
  CpuEnv --> Runtime["拷贝 .text/.data，清零 .bss"]
  Runtime --> Entry["components.c: entry()"]
  Entry --> Startup["rtthread_startup()"]
  Startup --> Board["rt_hw_board_init()"]
  Board --> MainThreadCreate["rt_application_init(): 创建 main 线程"]
  MainThreadCreate --> Scheduler["rt_system_scheduler_start()"]
  Scheduler --> MainThread["main_thread_entry()"]
  MainThread --> Components["rt_components_init()"]
  Components --> Main["applications/sys/main()"]
  Main --> PosInit["rt_hw_board_pos_init()"]
  PosInit --> IpcReady["ipc_msg_init + ipc_cmd_init + hal_ipcm_init"]
