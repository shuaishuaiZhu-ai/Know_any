// <<<>>> 三引号怎么降级 + 参数/配置经 TLS 暂存
// 源码确认 2026-06-28 src/aica_platform.cpp（configureCall/setupArgument/popExec）
digraph cfg {
  rankdir=TB; bgcolor="white";
  node [shape=box, style="rounded,filled", fontname="Noto Sans CJK SC",
        fontsize=12, color="#3b4252", penwidth=1.1, margin="0.18,0.11"];
  edge [fontname="Noto Sans CJK SC", fontsize=10, color="#4c566a", arrowsize=0.7];
  nodesep=0.4; ranksep=0.45;

  src [label="add1<<<grid, block, shm, stream>>>(args)\n（编译器插桩展开）", fillcolor="#e5e9f0"];

  push [label="__aicaPushCallConfiguration(grid, block, shm, stream)\n→ PlatformState::configureCall()", fillcolor="#eceff4"];
  arg  [label="__aicaSetupArgument(arg, size, offset)（逐参数）\n→ PlatformState::setupArgument()", fillcolor="#eceff4"];

  tls  [label="thread_local TLS\n暂存 launch 配置 + 参数 buffer", fillcolor="#fff7e6", color="#d0a070"];

  pop  [label="__aicaLaunchKernel → popExec()\n取回配置+参数", fillcolor="#eceff4"];
  call [label="aicaLaunchKernel(func, grid, block, params, ...)\n（进入主调用链，见 k1）", fillcolor="#d8ead0", color="#a3be8c"];

  src -> push -> arg;
  push -> tls [style=dashed, color="#d0a070"];
  arg  -> tls [style=dashed, color="#d0a070"];
  arg -> pop;
  tls -> pop [style=dashed, color="#d0a070", label="读回", fontname="Noto Sans CJK SC", fontsize=9, fontcolor="#b08030"];
  pop -> call;
}
