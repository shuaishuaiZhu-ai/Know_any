// 命令包类型 + aica_head_t + kernel dispatch packet 字段布局
// 源码确认 2026-06-28 include/aica_packet_def.h
digraph pkt {
  rankdir=LR; bgcolor="white";
  node [shape=box, style="rounded,filled", fontname="Noto Sans CJK SC",
        fontsize=11, color="#3b4252", penwidth=1.1, margin="0.16,0.1"];
  edge [color="#4c566a", arrowsize=0.7];
  nodesep=0.4; ranksep=0.6;

  types [label="aica_packet_type_t（cp_operator）\l──────────────\l0x10 KERNEL_DISPATCH（kernel 直发）\l0x11 SDMA（DMA 拷贝）\l0x20/21/22 ATOMIC add/swap/cmp_swap\l0x30 BARRIER（事件 signal）\l0x31 BARRIER_WAIT（事件等待）\l0x40 BARRIER_WAIT_HOST\l0xEE NOP\l",
         shape=note, fillcolor="#fff7e6", color="#d0a070", fontsize=10];

  head [label="aica_head_t（4B 联合体）\l──────────────\lcp_operator : 8   包类型\lbody_size : 5     包体字数(<=31)\lreserved_1 : 11   (→ hcqdid/asid)\lblock_mask : 4    依赖：compute/dma/video/atomic\lreserved_2 : 4\l",
         fillcolor="#eceff4", fontsize=10];

  body [label="aica_kernel_dispatch_packet_t（~32 字 / 128B）\l──────────────\lheader + stream_id/seq_id（调试定位）\lgrid_dim_x/y/z · block_dim_x/y/z · cluster_dim\lcta_num · cluster_ctrl（cluster 位图/模式）\licache_base + init_pc → pa_init_addr（入口）\llocal_base · local_step · const_base（参数/常量）\ltrf_size · shm_size（每 block 共享内存）\lpacket_done（完成后算子）\lcfg_addr（寄存器配置）\lfence_addr + fence_value（完成写 fence）\lICodLen/CCodLen（代码长度）· scatter_cfg\l",
         fillcolor="#d8ead0", color="#a3be8c", fontsize=10];

  types -> head [label="cp_operator=0x10", fontname="Noto Sans CJK SC", fontsize=9, fontcolor="#b08030"];
  head -> body [label="作为首字段", fontname="Noto Sans CJK SC", fontsize=9, fontcolor="#7b8394"];
}
