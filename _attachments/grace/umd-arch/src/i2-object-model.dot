// 运行时对象模型：Runtime → 设备 → agent/虚拟GPU/内存池 + TLS
// 源码确认 2026-06-28
digraph objmodel {
  rankdir=TB; bgcolor="white";
  node [shape=box, style="rounded,filled", fontname="Noto Sans CJK SC",
        fontsize=12, color="#3b4252", penwidth=1.1, margin="0.18,0.11"];
  edge [fontname="Noto Sans CJK SC", fontsize=10, color="#4c566a", arrowsize=0.7];
  nodesep=0.45; ranksep=0.45;

  rt   [label="Runtime（单例）\ng_devices[] · gpu_agents[]", fillcolor="#e5e9f0"];
  adev [label="aica::Device（每设备）\nNullStream（懒建）· helper copy stream", fillcolor="#eceff4"];
  gdev [label="aigc::Device  ←  grace::Device\nISA · KMD context 句柄 · info()", fillcolor="#e8f0e6", color="#a3be8c"];
  agent[label="GpuAgent\nISA · BlitQueue · DMA", fillcolor="#eceff4"];
  vgpu [label="grace::VirtualGPU（每 stream 一个）\n绑定一条硬件 ring buffer\nsubmitKernel / submitDMACopy", fillcolor="#e8f0e6", color="#a3be8c"];
  pool [label="内存池 MemoryManager / FenceMemoryPool\nMemObjMap（VA→Memory）", fillcolor="#eceff4"];
  tls  [label="thread_local TlsAggregator\n当前设备 / 当前流 / last error / launch 配置", fillcolor="#fff7e6", color="#d0a070"];

  rt -> adev [label="1..N"];
  adev -> gdev [label="包装"];
  gdev -> agent;
  adev -> vgpu [label="每 stream"];
  gdev -> pool;
  rt -> tls [label="每线程", style=dashed, color="#d0a070", fontcolor="#b08030"];
}
