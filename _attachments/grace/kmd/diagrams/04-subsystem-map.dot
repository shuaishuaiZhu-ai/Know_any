// 子系统地图：kmd 核心的几大块、对应文件与本知识库章节
digraph subsystem_map {
  rankdir=LR;
  bgcolor="white";
  fontname="Noto Sans CJK SC";
  node [fontname="Noto Sans CJK SC", fontsize=11, shape=box,
        style="rounded,filled", color="#9fb3c8", fillcolor="#eef3fb", margin="0.20,0.12"];
  edge [color="#7b8794", penwidth=1.2, arrowsize=0.7];

  core [label="kmd 可移植核心\nkmdlib/", shape=box, style="rounded,filled,bold",
        fillcolor="#e3f0e3", color="#5a9367", penwidth=2.0, fontsize=12];

  ioctl [label="ioctl ABI 与派发\naigc_ioctl.c · aigc_fops.c\naigc_ioctl_tab.h\n→ 第 03 章"];
  mem   [label="内存与页表\naigc_mem_handle.c · aigc_devm.c\naigc_page_table.c · genalloc.c\n→ 第 04 章"];
  sub   [label="提交 / 事件 / 中断\naigc_cmd*.c · aigc_cp_ring.c\naigc_sched.c · aigc_interrupt*.c · aigc_kmd_fence.c\n→ 第 05 章"];
  hal   [label="Grace HAL\nhal/grace/* · regs/*\n→ 第 06 章"];
  build [label="构建与测试\nKbuild · Makefile\nkmd/test/* · kmd/scripts/*\n→ 第 07 章"];

  core -> ioctl;
  core -> mem;
  core -> sub;
  core -> hal;
  core -> build;
}
