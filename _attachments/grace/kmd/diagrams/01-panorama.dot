// kmd 全景图：软件栈中 kmd 的位置，以及它和 fw 的对话
digraph panorama {
  rankdir=TB;
  bgcolor="white";
  fontname="Noto Sans CJK SC";
  node  [fontname="Noto Sans CJK SC", fontsize=12, shape=box,
         style="rounded,filled", color="#9fb3c8", fillcolor="#eef3fb", margin="0.22,0.14"];
  edge  [fontname="Noto Sans CJK SC", fontsize=11, color="#52606d", penwidth=1.3];

  umd   [label="UMD\n应用 / 运行时"];
  thunk [label="ajthunk 用户态库\nThunk_* C API"];
  dev   [label="/dev/aigcN  字符设备\nioctl(fd, AIP_*, args)", fillcolor="#fff4e0", color="#d9a441"];
  kmd   [label="kmd  内核态驱动 (aigc.ko)\n本知识库讲的就是这一层",
         fillcolor="#e3f0e3", color="#5a9367", penwidth=2.2];
  hw    [label="Grace GPU 硬件", fillcolor="#f3e4f0", color="#a86fa0"];
  fw    [label="fw  片上固件\n(IMC / CP master，姊妹项目)", fillcolor="#f3e4f0", color="#a86fa0"];

  umd -> thunk   [label="调用 C API"];
  thunk -> dev   [label="系统调用"];
  dev  -> kmd    [label="进入内核"];
  kmd  -> hw     [label="寄存器读写 + DMA"];
  kmd  -> fw     [label="CP / IMC IPC 环", style=dashed, constraint=false];
  fw   -> hw     [label="驱动片内", style=dashed];

  { rank=same; hw; fw; }
}
